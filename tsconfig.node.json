{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/main/*"],
      "@browser/*": ["src/browser/*"],
      "@actions/*": ["src/actions/*"],
      "@workflows/*": ["src/workflows/*"],
      "@parsers/*": ["src/parsers/*"],
      "@bg/*": ["src/bg/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/browser/**/*",
    "src/actions/**/*",
    "src/workflows/**/*",
    "src/parsers/**/*",
    "src/bg/**/*",
    "src/shared/**/*",
    "src/scripts/**/*",
    "tests/unit/**/*",
    "electron.vite.config.ts",
    "vitest.config.ts"
  ]
}
